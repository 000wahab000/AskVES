# =============================================================================
#  AskVES — Environment Variables
#  Copy this file to .env and fill in your own keys before running the app.
#
#     cp .env.example .env
#
#  NEVER commit your .env file to Git. It is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# 🤖 GROQ API  (Primary AI — fast LLM inference)
# -----------------------------------------------------------------------------
# You can supply one key or a comma-separated list of keys.
# Multiple keys enable automatic key rotation when rate limits are hit.
#
# How to get:
#   1. Go to https://console.groq.com
#   2. Sign up / log in (free account is enough)
#   3. Click "API Keys" in the sidebar → "Create API Key"
#   4. Copy the key (starts with gsk_...)
#   5. Paste it below. For multiple keys, separate with commas — no spaces.
#
GROQ_API_KEYS=gsk_YOUR_KEY_1,gsk_YOUR_KEY_2

# Optional: a dedicated Groq key used only for Whisper voice transcription.
# If left empty, the first key from GROQ_API_KEYS is used instead.
# Recommended if you want voice usage to not eat into your chat quota.
GROQ_VOICE_KEY=gsk_YOUR_VOICE_KEY


# -----------------------------------------------------------------------------
# ✨ GEMINI API  (Fallback AI — used when Groq is rate-limited)
# -----------------------------------------------------------------------------
# How to get:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Sign in with any Google account
#   3. Click "Create API Key" → select or create a Google Cloud project
#   4. Copy the key (starts with AIza...)
#
GEMINI_API_KEY=AIza_YOUR_GEMINI_KEY


# -----------------------------------------------------------------------------
# 🗄️ SUPABASE  (Cloud database — stores all campus data)
# -----------------------------------------------------------------------------
# How to get:
#   1. Go to https://supabase.com and create a free account
#   2. Click "New Project" and fill in the project details
#   3. Once the project is ready, go to Project Settings → API
#   4. Copy the "Project URL" → paste as SUPABASE_URL
#   5. Copy the "anon / public" key → paste as SUPABASE_KEY
#   6. In the Table Editor, create a table called "campus_data" with columns:
#        id   text  (Primary Key)
#        data jsonb
#   7. Run migrate_to_supabase.py to upload the local JSON files to Supabase
#
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key


# -----------------------------------------------------------------------------
# 🔑 GOOGLE OAUTH  (Login with Google for the Community board)
# -----------------------------------------------------------------------------
# How to get:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project (or select an existing one)
#   3. Go to "APIs & Services" → "OAuth consent screen"
#      - Set User Type to "External"
#      - Fill in App name, support email, and developer email
#   4. Go to "APIs & Services" → "Credentials" → "Create Credentials"
#      → "OAuth 2.0 Client ID"
#      - Application type: Web application
#      - Authorized redirect URIs: add http://localhost:8000/auth/callback
#        (and your production URL if deploying, e.g. https://yourapp.onrender.com/auth/callback)
#   5. Copy the Client ID and Client Secret below
#
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# The public URL of this app. Used to build the OAuth redirect URI.
# For local development: http://localhost:8000
# For production (Render/Railway): https://your-deployed-app-url.com
APP_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# 📱 TWILIO  (WhatsApp integration — optional, only needed for WhatsApp bot)
# -----------------------------------------------------------------------------
# How to get:
#   1. Go to https://www.twilio.com and create a free account
#   2. In the Twilio Console, your Account SID and Auth Token are on the
#      main dashboard page
#   3. To enable WhatsApp: go to Messaging → Try it out → Send a WhatsApp message
#      and follow the sandbox setup instructions
#   4. Set your webhook URL to: https://your-app-url.com/whatsapp
#
# Leave these empty if you do not need the WhatsApp feature.
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token


# -----------------------------------------------------------------------------
# 🔒 ADMIN PASSWORD  (Protects the /admin panel and /api/admin routes)
# -----------------------------------------------------------------------------
# Choose a strong, unique password. Do NOT use "admin123" in production.
# The app will use this to verify the Authorization: Bearer <password> header.
#
ADMIN_PASSWORD=choose_a_strong_password_here
